</span>    <span class="n">cur_path</span> <span class="o">=</span> <span class="n">train_dir</span> <span class="o">+</span> <span class="s">"</span><span class="se">\\</span><span class="s">train</span><span class="se">\\</span><span class="s">"</span> <span class="o">+</span> <span class="n">class_names</span><span class="p">[</span><span class="n">label</span><span class="p">]</span> <span class="o">+</span> <span class="s">"</span><span class="se">\\</span><span class="s">"</span>
    
    <span class="c1"># loop over the images in the dataset
