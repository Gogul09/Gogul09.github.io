      <span class="n">os</span><span class="o">.</span><span class="n">rename</span><span class="p">(</span><span class="n">original_path</span><span class="p">,</span> <span class="n">cur_path</span> <span class="o">+</span> <span class="n">image_file_name</span><span class="p">)</span>
    
